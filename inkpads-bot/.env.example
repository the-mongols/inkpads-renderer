# InkPads Tactical Bot Configuration

# YOUR DISCORD BOT TOKEN (Get this from https://discord.com/developers/applications)
DISCORD_TOKEN=your_token_here

# Path to your World of Warships installation
# Windows Example: C:\Games\World_of_Warships
# If not set, the bot defaults to the standard Windows path.
WOWS_PATH=C:\Games\World_of_Warships

# Optional: Path to the minimap_renderer binary
# If not set, the bot will look in its own folder and the project's build directories.
# RENDERER_PATH=.\minimap_renderer.exe
